# App
APP_ENV=dev
PORT=8080
LOG_LEVEL=info
REQUEST_ID_HEADER=X-Request-Id
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-Id
CORS_EXPOSE_HEADERS=X-Request-Id
CORS_ALLOW_CREDENTIALS=false

# Database (Postgres)
# Local
DATABASE_URL=postgres://[usuario]:[senha]@[host]:[porta]/[database]?sslmode=disable
# Supabase (example)
# DATABASE_URL=postgres://postgres.<project-ref>:SUA_SENHA@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# Firebase Admin (FCM)
GOOGLE_APPLICATION_CREDENTIALS=/app/config/firebase-admin.json

# Auth (JWT)
JWT_SECRET=

# AI Provider
AI_PROVIDER=groq
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1/chat/completions
AI_MODEL=llama-3.3-70b-versatile
AI_FALLBACK_MODEL=llama-3.1-8b-instant
AI_FALLBACK_ON_NEEDS_REVIEW=false
AI_TIMEOUT=15s
AI_MAX_RETRIES=2

# Resend
RESEND_API_KEY=
RESEND_FROM='Organiq <noreply@resend.dev>'
DIGEST_JOB_INTERVAL=30m

# Timeouts
READ_TIMEOUT=5s
WRITE_TIMEOUT=10s
IDLE_TIMEOUT=60s
